# Copy to .env for local experiments. Do not commit real keys.
AMIVOICE_API_KEY=
AMIVOICE_ENDPOINT=https://acp-api.amivoice.com/v1/nolog/recognize
AMIVOICE_WEBSOCKET_ENDPOINT=wss://acp-api.amivoice.com/v1/nolog/
AMIVOICE_ENGINE=-a-general
AMIVOICE_TRANSPORT=websocket
AMIVOICE_DICT_PATH=../data/amivoice/dict.txt
AMIVOICE_PROFILE_WORDS_LIMIT=200
KOECRAFT_SPEECH_PROVIDER=amivoice
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
LLM_API_KEY=
OPENAI_MODEL=gpt-4o-mini
KOECRAFT_LLM_FALLBACK=true
KOECRAFT_AGENT_PORT=8787
KOECRAFT_EXECUTOR_URL=ws://127.0.0.1:8787
KOECRAFT_REQUEST_TIMEOUT_MS=5000
KOECRAFT_TRACE_DIR=../logs/traces
KOECRAFT_MAX_REPLANS=5
KOECRAFT_NATIVE_MIC=false
KOECRAFT_NATIVE_MIC_FORMAT=avfoundation
KOECRAFT_NATIVE_MIC_INPUT=:0
KOECRAFT_NATIVE_MIC_SILENCE_MS=2000
KOECRAFT_NATIVE_MIC_MIN_RECORDING_MS=700
KOECRAFT_NATIVE_MIC_MAX_RECORDING_MS=12000
KOECRAFT_NATIVE_MIC_SPEECH_THRESHOLD=0.035
KOECRAFT_NATIVE_MIC_SILENCE_THRESHOLD=0.018
KOECRAFT_VOICE_ADAPTIVE_NOISE=true
KOECRAFT_VOICE_ADAPTIVE_NOISE_WARMUP_MS=450
KOECRAFT_VOICE_ADAPTIVE_NOISE_MULTIPLIER=3.0
KOECRAFT_VOICE_ADAPTIVE_NOISE_MIN_THRESHOLD=0.0035
KOECRAFT_VOICE_PCM_NORMALIZE=true
KOECRAFT_VOICE_PCM_NORMALIZE_TARGET_RMS=0.035
KOECRAFT_VOICE_PCM_NORMALIZE_MAX_GAIN=3.0
KOECRAFT_VOICE_PCM_SOFT_CLIP=true
KOECRAFT_TTS_INTERRUPT_ON_SPEECH=true
KOECRAFT_TTS_INTERRUPT_RMS_THRESHOLD=0.018
KOECRAFT_EXECUTOR_MAX_WATCHDOG_RECOVERY_ATTEMPTS=3
